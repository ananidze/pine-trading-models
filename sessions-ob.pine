//@version=6
indicator('Sessions + Order Blocks', 'Sessions + OB', overlay = true,
     max_bars_back = 500, max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500)

// ============================================================================
// INPUTS — SESSIONS
// ============================================================================

// Session A — New York
show_sesa   = input.bool(true,               '',          inline = 'sesa',          group = 'Session A')
sesa_txt    = input.string('New York',       '',          inline = 'sesa',          group = 'Session A')
sesa_ses    = input.session('1300-2200',     '',          inline = 'sesa',          group = 'Session A', tooltip = 'Session window in HHMM-HHMM format. Interpreted in the timezone set below.')
sesa_css    = input.color(#ff6b35,           '',          inline = 'sesa',          group = 'Session A')
sesa_range  = input.bool(true,  'Range',                  inline = 'sesa_overlays', group = 'Session A')


// Session B — London
show_sesb   = input.bool(true,               '',          inline = 'sesb',          group = 'Session B')
sesb_txt    = input.string('London',         '',          inline = 'sesb',          group = 'Session B')
sesb_ses    = input.session('0700-1600',     '',          inline = 'sesb',          group = 'Session B', tooltip = 'Session window in HHMM-HHMM format. Interpreted in the timezone set below.')
sesb_css    = input.color(#3d7aed,           '',          inline = 'sesb',          group = 'Session B')
sesb_range  = input.bool(true,  'Range',                  inline = 'sesb_overlays', group = 'Session B')


// Session C — Tokyo
show_sesc   = input.bool(true,               '',          inline = 'sesc',          group = 'Session C')
sesc_txt    = input.string('Tokyo',          '',          inline = 'sesc',          group = 'Session C')
sesc_ses    = input.session('0000-0900',     '',          inline = 'sesc',          group = 'Session C', tooltip = 'Session window in HHMM-HHMM format. Interpreted in the timezone set below.')
sesc_css    = input.color(#e91e8c,           '',          inline = 'sesc',          group = 'Session C')
sesc_range  = input.bool(true,  'Range',                  inline = 'sesc_overlays', group = 'Session C')


// Session D — Sydney
show_sesd   = input.bool(true,               '',          inline = 'sesd',          group = 'Session D')
sesd_txt    = input.string('Sydney',         '',          inline = 'sesd',          group = 'Session D')
sesd_ses    = input.session('2100-0600',     '',          inline = 'sesd',          group = 'Session D', tooltip = 'Session window in HHMM-HHMM format. Interpreted in the timezone set below.')
sesd_css    = input.color(#f0c040,           '',          inline = 'sesd',          group = 'Session D')
sesd_range  = input.bool(true,  'Range',                  inline = 'sesd_overlays', group = 'Session D')


// Timezone
tz_incr      = input.int(0,    'UTC (+/-)',              group = 'Timezone', minval = -12, maxval = 14, tooltip = 'UTC offset in whole hours. Ignored when Use Exchange Timezone is enabled.')
use_exchange = input.bool(false, 'Use Exchange Timezone', group = 'Timezone', tooltip = 'When enabled, session windows are interpreted in the instrument\'s exchange timezone, overriding the UTC offset.')

// Range Style
bg_transp    = input.int(88,   'Range Fill Opacity',  group = 'Range Style', minval = 0, maxval = 100, tooltip = 'Transparency of the session range fill. 0 = fully opaque, 100 = invisible.')
show_outline = input.bool(true,  'Range Border',       group = 'Range Style', tooltip = 'Show a dotted border around each session range box.')
show_txt     = input.bool(true,  'Session Label',      group = 'Range Style', tooltip = 'Display the session name at the top-left of its range box.')


// Dividers
show_ses_div = input.bool(false, 'Session Divider', group = 'Dividers', tooltip = 'Plot a tick marker along the chart bottom for every bar inside an active session.')
show_day_div = input.bool(true,  'Daily Divider',   group = 'Dividers', tooltip = 'Draw a dashed vertical line and day-of-week label at each daily boundary.')

// ============================================================================
// INPUTS — ORDER BLOCKS
// ============================================================================

length        = input.int(5,   'Pivot Length',       minval = 1, maxval = 50,  group = 'OB Detection', tooltip = 'Bars on each side required to confirm a volume pivot high. Larger values produce fewer but more significant order blocks.')
mitigation    = input.string('Wick', 'Mitigation',   options = ['Wick', 'Close'], group = 'OB Detection', tooltip = 'Wick: OB is invalidated when price wicks through its boundary.\nClose: OB is invalidated only when price closes beyond its boundary.')

bull_ext_last = input.int(3,   'Max Bullish OBs',   minval = 1, maxval = 10,  group = 'Bullish OB', tooltip = 'Maximum number of unmitigated bullish order blocks shown at once.')
bg_bull_css   = input.color(color.new(#1a9e00, 82), 'Fill',   inline = 'bull', group = 'Bullish OB')
bull_css      = input.color(#1a9e00, 'Border',                 inline = 'bull', group = 'Bullish OB')
bull_avg_css  = input.color(color.new(#9598a1, 40), 'Mid Line', inline = 'bull', group = 'Bullish OB')

bear_ext_last = input.int(3,   'Max Bearish OBs',   minval = 1, maxval = 10,  group = 'Bearish OB', tooltip = 'Maximum number of unmitigated bearish order blocks shown at once.')
bg_bear_css   = input.color(color.new(#e01000, 82), 'Fill',   inline = 'bear', group = 'Bearish OB')
bear_css      = input.color(#e01000, 'Border',                 inline = 'bear', group = 'Bearish OB')
bear_avg_css  = input.color(color.new(#9598a1, 40), 'Mid Line', inline = 'bear', group = 'Bearish OB')

line_style    = input.string('⎯⎯⎯', 'Mid Line Style', options = ['⎯⎯⎯', '----', '····'], group = 'OB Style')
line_width    = input.int(1,   'Mid Line Width',      minval = 1, maxval = 4,   group = 'OB Style')
show_labels   = input.bool(true, 'Show Labels',                                  group = 'OB Style', tooltip = 'Display "Bull OB" / "Bear OB" text at the left edge of each order block.')
label_size_in = input.string('Small', 'Label Size',
     options = ['Tiny', 'Small', 'Normal', 'Large', 'Adaptive'], group = 'OB Style', tooltip = 'Adaptive scales text automatically based on chart timeframe.')

// ============================================================================
// INPUTS — OB SCORING
// ============================================================================

show_ob_score  = input.bool(true,       'Show Score',  group = 'OB Scoring', tooltip = 'Append a 0–100 strength score to each order block label. Score = volume impulse (0–50) + OB height vs ATR (0–50).')
ob_score_size  = input.string(size.tiny, 'Score Size', group = 'OB Scoring',
     options = [size.tiny, size.small, size.normal])

// ============================================================================
// INPUTS — LIQUIDITY (EQH / EQL)
// ============================================================================

show_liq      = input.bool(true,  'Show Liquidity',    group = 'Liquidity (EQH/EQL)', tooltip = 'Detect and plot equal highs (BSL) and equal lows (SSL).')
liq_length    = input.int(10,     'Pivot Length',      group = 'Liquidity (EQH/EQL)', minval = 2, maxval = 50, tooltip = 'Bars needed strictly to the left and right to form a swing.')
liq_tolerance = input.int(3,      'Tolerance (Ticks)', group = 'Liquidity (EQH/EQL)', minval = 0, tooltip = 'Max distance in ticks between pivots to be considered Equal Highs / Lows.')
liq_max       = input.int(5,      'Max Lines',         group = 'Liquidity (EQH/EQL)', minval = 1, maxval = 20)
liq_bsl_css   = input.color(color.new(#e01000, 0), 'BSL Color', inline = 'liq_css', group = 'Liquidity (EQH/EQL)')
liq_ssl_css   = input.color(color.new(#1a9e00, 0), 'SSL Color', inline = 'liq_css', group = 'Liquidity (EQH/EQL)')

// ============================================================================
// INPUTS — PREMIUM / DISCOUNT ZONES
// ============================================================================

grp_pd             = 'Premium & Discount'
show_pd            = input.bool(true,  'Show P&D Zones',        group = grp_pd,
     tooltip = 'Show Premium (above 50%) and Discount (below 50%) zones based on the most recent swing high and swing low.')
pd_swing_length    = input.int(20,     'Swing Length',          group = grp_pd, minval = 5, maxval = 100,
     tooltip = 'Bars on each side used to detect the swing high and swing low that define the P&D range.')
show_pd_zones      = input.bool(true,  'Shade Zones',           group = grp_pd,
     tooltip = 'Fill the Premium and Discount half-ranges with a translucent color.')
pd_premium_css     = input.color(color.new(#ef5350, 88), 'Premium Fill', inline = 'pd_css', group = grp_pd)
pd_discount_css    = input.color(color.new(#26a69a, 88), 'Discount Fill', inline = 'pd_css', group = grp_pd)
pd_eq_css          = input.color(color.new(#9598a1, 55), 'Equilibrium Line', group = grp_pd,
     tooltip = 'Color of the midline drawn at the 50% equilibrium level.')
pd_use_filter      = input.bool(true,  'Use as Setup Filter',   group = grp_pd,
     tooltip = 'When enabled: bullish ICT setups are only valid in Discount, bearish ICT setups only in Premium.')

// ============================================================================
// INPUTS — DISPLACEMENT
// ============================================================================

show_disp      = input.bool(true,   'Show Displacement',   group = 'Displacement', tooltip = 'Detect and highlight strong impulsive candles (displacement).')
disp_mult      = input.float(1.5,   'ATR Multiplier',      group = 'Displacement', minval = 0.1, step = 0.1, tooltip = 'Minimum candle body size as a multiple of ATR(14) to qualify as displacement. Higher = fewer, stronger moves.')
disp_bull_css  = input.color(color.new(#00bcd4, 75), 'Bullish Color', group = 'Displacement', tooltip = 'Color used when a bullish displacement candle is detected.')
disp_bear_css  = input.color(color.new(#ff9800, 75), 'Bearish Color', group = 'Displacement', tooltip = 'Color used when a bearish displacement candle is detected.')

// ============================================================================
// INPUTS — ICT ENTRY MODEL
// ============================================================================

grp_ict            = 'ICT Entry Model'
ict_enable         = input.bool(true,  'Enable Entry Model', group = grp_ict,
     tooltip = 'Activates the full 4-step ICT setup filter:\n1. SSL/BSL sweep\n2. Displacement\n3. MSS\n4. Retrace into OB or FVG\nValid zones are highlighted — no arrows or signals.')
ict_mss_lookback   = input.int(20,  'MSS Lookback (bars)', group = grp_ict, minval = 5, maxval = 100,
     tooltip = 'Bars to look back for the swing high/low used to detect a Market Structure Shift after the sweep.')
ict_model_window   = input.int(50,  'Setup Window (bars)', group = grp_ict, minval = 10, maxval = 200,
     tooltip = 'Maximum bars after the sweep for steps 2–4 to complete. Resets the state machine after this window.')
ict_bull_valid_css = input.color(color.new(#4169E1, 55), 'Valid Bullish Zone',  inline = 'ict_css', group = grp_ict,
     tooltip = 'Fill color applied to OB/FVG zones when a valid bullish setup is active and price retraces into them.')
ict_bear_valid_css = input.color(color.new(#708090, 55), 'Valid Bearish Zone',  inline = 'ict_css', group = grp_ict,
     tooltip = 'Fill color applied to OB/FVG zones when a valid bearish setup is active and price retraces into them.')
ict_alert_valid    = input.bool(true, 'Alert on Valid Setup', group = grp_ict,
     tooltip = 'Fire an alert when price retraces into a valid OB or FVG after the full 4-step sequence is confirmed.')

// ============================================================================
// INPUTS — FAIR VALUE GAPS
// ============================================================================

show_fvg          = input.bool(true,  'Show FVGs',               group = 'Fair Value Gaps', tooltip = 'Display Fair Value Gap zones — 3-bar price imbalances where no trading occurred.')
fvg_require_disp  = input.bool(true,  'Require Displacement',    group = 'Fair Value Gaps', tooltip = 'Only create an FVG when the middle bar of the 3-bar pattern is a displacement candle (strong impulse). Filters out low-quality gaps.')
fvg_bull_css = input.color(color.new(#1a9e00, 85), 'Bullish Fill', inline = 'fvg_css', group = 'Fair Value Gaps')
fvg_bear_css = input.color(color.new(#e01000, 85), 'Bearish Fill', inline = 'fvg_css', group = 'Fair Value Gaps')
fvg_max      = input.int(5,      'Max FVGs',        group = 'Fair Value Gaps', minval = 1, maxval = 20, tooltip = 'Maximum number of unmitigated FVG zones shown per side.')
fvg_mitigate = input.string('Partial', 'Mitigation', group = 'Fair Value Gaps',
     options = ['Partial', 'Full'],
     tooltip = 'Partial: FVG is removed on first price wick into the zone.\nFull: FVG is removed only when price closes through the entire zone.')
show_fvg_labels = input.bool(true, 'Show Labels',  inline = 'fvg_lbl', group = 'Fair Value Gaps', tooltip = 'Display "Bull FVG" / "Bear FVG" text at the left edge of each zone.')
fvg_lbl_sz_in   = input.string('Tiny', '',      inline = 'fvg_lbl', group = 'Fair Value Gaps',
     options = ['Tiny', 'Small', 'Normal', 'Adaptive'])

// ============================================================================
// ADAPTIVE SIZING
// ============================================================================

get_adaptive_size(opt) =>
    switch opt
        'Tiny'     => size.tiny
        'Small'    => size.small
        'Normal'   => size.normal
        'Large'    => size.large
        'Adaptive' => timeframe.period == '1' ? size.tiny : timeframe.period == '5' or timeframe.period == '15' ? size.small : timeframe.period == '60' or timeframe.period == '240' ? size.normal : size.large
        => size.small

label_size     = get_adaptive_size(label_size_in)
fvg_label_size = get_adaptive_size(fvg_lbl_sz_in)

// ============================================================================
// FUNCTIONS — SESSIONS
// ============================================================================

n = bar_index


// Draw or update the session range box with a clean top-left label
get_range(session, session_name, session_css) =>
    var int   t   = 0
    var float bx_max = high
    var float bx_min = low
    var box   bx  = na
    var label lbl = na

    if session > session[1]
        t      := time
        bx_max := high
        bx_min := low

        bx := box.new(n, bx_max, n, bx_min,
             bgcolor      = color.new(session_css, bg_transp),
             border_color = show_outline ? color.new(session_css, 60) : na,
             border_style = line.style_dotted,
             border_width = 1)

        if show_txt
            lbl := label.new(t, bx_max, session_name,
                 xloc      = xloc.bar_time,
                 textcolor = color.new(session_css, 10),
                 style     = label.style_label_down,
                 color     = color.new(color.white, 100),
                 size      = size.tiny)

    if bool(session) and session == session[1]
        bx_max := math.max(high, bx_max)
        bx_min := math.min(low,  bx_min)
        box.set_top(bx, bx_max)
        box.set_rightbottom(bx, n, bx_min)
        if show_txt
            label.set_xy(lbl, int(math.avg(t, time)), bx_max)

    [bool(session) ? na : bx_max, bool(session) ? na : bx_min]

// ============================================================================
// FUNCTIONS — ORDER BLOCKS
// ============================================================================

line_style_from(style) =>
    switch style
        '⎯⎯⎯' => line.style_solid
        '----' => line.style_dashed
        '····' => line.style_dotted

// Accumulate OB coordinates into arrays when condition fires
// Now also accumulates a score value in parallel
get_coordinates(condition, top, btm, ob_val, score) =>
    var ob_top   = array.new_float(0)
    var ob_btm   = array.new_float(0)
    var ob_avg   = array.new_float(0)
    var ob_left  = array.new_int(0)
    var ob_score = array.new_float(0)
    float ob     = na

    if condition
        array.unshift(ob_top,   top)
        array.unshift(ob_btm,   btm)
        array.unshift(ob_avg,   math.avg(top, btm))
        array.unshift(ob_left,  time[length])
        array.unshift(ob_score, score)
        ob := ob_val

    [ob_top, ob_btm, ob_avg, ob_left, ob_score, ob]

// Remove mitigated OBs; iterate in reverse to avoid index-shift bugs
// Now also removes the parallel score entry
remove_mitigated(ob_top, ob_btm, ob_left, ob_avg, ob_score, target, bull) =>
    mitigated  = false
    target_arr = bull ? ob_btm : ob_top
    i          = array.size(target_arr) - 1

    while i >= 0
        breached = bull ? target < array.get(target_arr, i) : target > array.get(target_arr, i)
        if breached
            array.remove(ob_top,   i)
            array.remove(ob_btm,   i)
            array.remove(ob_avg,   i)
            array.remove(ob_left,  i)
            array.remove(ob_score, i)
            mitigated := true
        i -= 1

    mitigated

// Pre-allocate drawing objects on bar 0; reposition on last bar
// Accepts ob_score array and integrates strength score into label when show_ob_score is true
// Returns ob_box array so the ICT entry model can update individual box colors
set_order_blocks(ob_top, ob_btm, ob_left, ob_avg, ob_score, ext_last, bg_css, border_css, lvl_css, bull) =>
    var ob_box = array.new_box(0)
    var ob_lvl = array.new_line(0)
    var ob_lbl = array.new_label(0)

    if barstate.isfirst
        for i = 0 to ext_last - 1
            array.unshift(ob_box, box.new(na, na, na, na,
                 xloc         = xloc.bar_time,
                 extend       = extend.right,
                 bgcolor      = bg_css,
                 border_color = color.new(border_css, 55)))
            array.unshift(ob_lvl, line.new(na, na, na, na,
                 xloc   = xloc.bar_time,
                 extend = extend.right,
                 color  = lvl_css,
                 style  = line_style_from(line_style),
                 width  = line_width))
            array.unshift(ob_lbl, label.new(na, na, '',
                 xloc      = xloc.bar_time,
                 style     = label.style_label_left,
                 color     = color.new(color.black, 100),
                 textcolor = color.new(border_css, 20),
                 size      = label_size))

    if barstate.islast
        last = math.min(ext_last - 1, array.size(ob_top) - 1)

        // Hide slots that have no active OB data
        if last < ext_last - 1
            for i = last + 1 to ext_last - 1
                lbl = array.get(ob_lbl, i)
                label.set_style(lbl, label.style_none)
                label.set_text(lbl, '')

        if last >= 0
            for i = 0 to last
                bx    = array.get(ob_box,  i)
                lv    = array.get(ob_lvl,  i)
                lbl   = array.get(ob_lbl,  i)
                top_v = array.get(ob_top,  i)
                btm_v = array.get(ob_btm,  i)
                avg_v = array.get(ob_avg,  i)
                lft   = array.get(ob_left, i)

                box.set_lefttop(bx,     lft, top_v)
                box.set_rightbottom(bx, lft, btm_v)
                line.set_xy1(lv, lft,     avg_v)
                line.set_xy2(lv, lft + 1, avg_v)

                if show_labels
                    ob_lbl_txt  = bull ? 'Bull OB' : 'Bear OB'
                    score_v     = array.size(ob_score) > i ? array.get(ob_score, i) : 50.
                    score_int   = int(score_v)
                    lbl_txt     = show_ob_score ? ob_lbl_txt + '  ' + str.tostring(score_int) : ob_lbl_txt
                    lbl_css     = show_ob_score ? (score_v >= 70 ? border_css : score_v >= 40 ? color.new(border_css, 40) : color.new(border_css, 70)) : color.new(border_css, 20)
                    lbl_sz      = show_ob_score ? ob_score_size : label_size

                    label.set_xy(lbl, time, avg_v)
                    label.set_text(lbl, lbl_txt)
                    label.set_style(lbl, label.style_label_left)
                    label.set_textcolor(lbl, lbl_css)
                    label.set_size(lbl, lbl_sz)

    ob_box

// ============================================================================
// FUNCTIONS — OB SCORING
// ============================================================================

// Compute OB strength score (0–100) at pivot confirmation bar
// vol_score: pivot volume vs rolling average, normalized 0–50
// range_score: OB height as % of ATR, normalized 0–50
calc_ob_score(ob_top, ob_btm, atr_v, vol_v) =>
    vol_ratio  = vol_v > 0 ? volume[length] / vol_v : 1.
    vol_score  = math.min(50., (vol_ratio - 1.) * 25.)
    vol_score  := math.max(0., vol_score)

    ob_height   = math.abs(ob_top - ob_btm)
    range_ratio = atr_v > 0 ? ob_height / atr_v : 0.5
    range_score = math.min(50., range_ratio * 50.)
    range_score := math.max(0., range_score)

    math.min(100., math.max(0., vol_score + range_score))

// ============================================================================
// SESSION DETECTION
// ============================================================================

var string tz = use_exchange ? syminfo.timezone : str.format('UTC{0}{1}', tz_incr >= 0 ? '+' : '-', math.abs(tz_incr))

is_sesa = math.sign(nz(time(timeframe.period, sesa_ses, tz)))
is_sesb = math.sign(nz(time(timeframe.period, sesb_ses, tz)))
is_sesc = math.sign(nz(time(timeframe.period, sesc_ses, tz)))
is_sesd = math.sign(nz(time(timeframe.period, sesd_ses, tz)))

// Cache active-state booleans (used in dashboard + plotshape)
sesa_on = bool(is_sesa)
sesb_on = bool(is_sesb)
sesc_on = bool(is_sesc)
sesd_on = bool(is_sesd)



// ============================================================================
// SESSION OVERLAYS
// ============================================================================

// Ranges
if show_sesa and sesa_range
    get_range(is_sesa, sesa_txt, sesa_css)

if show_sesb and sesb_range
    get_range(is_sesb, sesb_txt, sesb_css)

if show_sesc and sesc_range
    get_range(is_sesc, sesc_txt, sesc_css)

if show_sesd and sesd_range
    get_range(is_sesd, sesd_txt, sesd_css)

// ============================================================================
// ORDER BLOCK CALCULATIONS
// ============================================================================

var os          = 0
var target_bull = 0.
var target_bear = 0.

upper = ta.highest(length)
lower = ta.lowest(length)

os := high[length] > upper ? 0 : low[length] < lower ? 1 : os[1]

if mitigation == 'Close'
    target_bull := ta.lowest(close, length)
    target_bear := ta.highest(close, length)
else
    target_bull := lower
    target_bear := upper

phv = ta.pivothigh(volume, length, length)

// Pre-compute OB scores at pivot bar (confirmed, no repainting)
bull_ob_top_raw  = hl2[length]
bull_ob_btm_raw  = low[length]
bear_ob_top_raw  = high[length]
bear_ob_btm_raw  = hl2[length]

// Global cache for scoring
sys_atr = ta.atr(14)
sys_vol = ta.sma(volume, 20)

bull_score = calc_ob_score(bull_ob_top_raw, bull_ob_btm_raw, sys_atr, sys_vol)
bear_score = calc_ob_score(bear_ob_top_raw, bear_ob_btm_raw, sys_atr, sys_vol)

// ============================================================================
// ORDER BLOCKS
// ============================================================================

[bull_top, bull_btm, bull_avg, bull_left, bull_scores, bull_ob] = get_coordinates(bool(phv) and os == 1, bull_ob_top_raw, bull_ob_btm_raw, low[length],  bull_score)
[bear_top, bear_btm, bear_avg, bear_left, bear_scores, bear_ob] = get_coordinates(bool(phv) and os == 0, bear_ob_top_raw, bear_ob_btm_raw, high[length], bear_score)

mitigated_bull = remove_mitigated(bull_top, bull_btm, bull_left, bull_avg, bull_scores, target_bull, true)
mitigated_bear = remove_mitigated(bear_top, bear_btm, bear_left, bear_avg, bear_scores, target_bear, false)

ob_box_bull = set_order_blocks(bull_top, bull_btm, bull_left, bull_avg, bull_scores, bull_ext_last, bg_bull_css, bull_css, bull_avg_css, true)
ob_box_bear = set_order_blocks(bear_top, bear_btm, bear_left, bear_avg, bear_scores, bear_ext_last, bg_bear_css, bear_css, bear_avg_css, false)

// ============================================================================
// DISPLACEMENT DETECTION
// ============================================================================

// Reuse sys_atr (ta.atr(14)) — already computed above
// Body must be >= ATR * multiplier AND candle must close in the direction of move
disp_body      = math.abs(close - open)
disp_threshold = sys_atr * disp_mult

disp_bull = show_disp and barstate.isconfirmed and disp_body >= disp_threshold and close > open
disp_bear = show_disp and barstate.isconfirmed and disp_body >= disp_threshold and close < open


// ============================================================================
// FAIR VALUE GAP DETECTION
// ============================================================================

// FVG detected at close of the middle bar (bar[1]) — confirmed, no repainting
// Bullish FVG: gap between high[2] and low[0]  (low[0] > high[2])
// Bearish FVG: gap between low[2] and high[0]  (high[0] < low[2])
// When fvg_require_disp is on, bar[1] (the impulse candle) must be a displacement bar
fvg_disp_bull_ok = not fvg_require_disp or disp_bull[1]
fvg_disp_bear_ok = not fvg_require_disp or disp_bear[1]
fvg_bull_cond = show_fvg and barstate.isconfirmed and low > high[2] and fvg_disp_bull_ok
fvg_bear_cond = show_fvg and barstate.isconfirmed and high < low[2] and fvg_disp_bear_ok

// FVG zone boundaries (set at detection bar)
fvg_bull_top_raw = low          // candle[0] low  = top of gap from below
fvg_bull_btm_raw = high[2]      // candle[2] high = bottom of gap

fvg_bear_top_raw = low[2]       // candle[2] low  = top of gap
fvg_bear_btm_raw = high         // candle[0] high = bottom of gap from above

// Persistent FVG zone arrays
var fvg_bull_tops  = array.new_float(0)
var fvg_bull_btms  = array.new_float(0)
var fvg_bull_lefts = array.new_int(0)
var fvg_bull_boxes = array.new_box(0)
var fvg_bull_lbls  = array.new_label(0)

var fvg_bear_tops  = array.new_float(0)
var fvg_bear_btms  = array.new_float(0)
var fvg_bear_lefts = array.new_int(0)
var fvg_bear_boxes = array.new_box(0)
var fvg_bear_lbls  = array.new_label(0)

// Add new bullish FVG
if fvg_bull_cond
    array.unshift(fvg_bull_tops,  fvg_bull_top_raw)
    array.unshift(fvg_bull_btms,  fvg_bull_btm_raw)
    array.unshift(fvg_bull_lefts, time[1])
    new_bx = box.new(time[1], fvg_bull_top_raw, time, fvg_bull_btm_raw,
         xloc         = xloc.bar_time,
         extend       = extend.right,
         bgcolor      = fvg_bull_css,
         border_color = na)
    array.unshift(fvg_bull_boxes, new_bx)
    fvg_bull_mid_t = math.avg(time[1], time)
    new_lbl = show_fvg_labels ? label.new(int(fvg_bull_mid_t), math.avg(fvg_bull_top_raw, fvg_bull_btm_raw), 'Bull FVG',
         xloc      = xloc.bar_time,
         style     = label.style_label_left,
         color     = color.new(color.black, 100),
         textcolor = color.new(#1a9e00, 20),
         size      = fvg_label_size) : label.new(na, na, '', xloc = xloc.bar_time, style = label.style_none)
    array.unshift(fvg_bull_lbls, new_lbl)

    // Trim to max
    if array.size(fvg_bull_tops) > fvg_max
        old_bx  = array.pop(fvg_bull_boxes)
        old_lbl = array.pop(fvg_bull_lbls)
        box.delete(old_bx)
        label.delete(old_lbl)
        array.pop(fvg_bull_tops)
        array.pop(fvg_bull_btms)
        array.pop(fvg_bull_lefts)

// Add new bearish FVG
if fvg_bear_cond
    array.unshift(fvg_bear_tops,  fvg_bear_top_raw)
    array.unshift(fvg_bear_btms,  fvg_bear_btm_raw)
    array.unshift(fvg_bear_lefts, time[1])
    new_bx = box.new(time[1], fvg_bear_top_raw, time, fvg_bear_btm_raw,
         xloc         = xloc.bar_time,
         extend       = extend.right,
         bgcolor      = fvg_bear_css,
         border_color = na)
    array.unshift(fvg_bear_boxes, new_bx)
    fvg_bear_mid_t = math.avg(time[1], time)
    new_lbl = show_fvg_labels ? label.new(int(fvg_bear_mid_t), math.avg(fvg_bear_top_raw, fvg_bear_btm_raw), 'Bear FVG',
         xloc      = xloc.bar_time,
         style     = label.style_label_left,
         color     = color.new(color.black, 100),
         textcolor = color.new(#e01000, 20),
         size      = fvg_label_size) : label.new(na, na, '', xloc = xloc.bar_time, style = label.style_none)
    array.unshift(fvg_bear_lbls, new_lbl)

    // Trim to max
    if array.size(fvg_bear_tops) > fvg_max
        old_bx  = array.pop(fvg_bear_boxes)
        old_lbl = array.pop(fvg_bear_lbls)
        box.delete(old_bx)
        label.delete(old_lbl)
        array.pop(fvg_bear_tops)
        array.pop(fvg_bear_btms)
        array.pop(fvg_bear_lefts)

// ============================================================================
// FAIR VALUE GAP MITIGATION
// ============================================================================

var bool fvg_bull_mitigated = false
var bool fvg_bear_mitigated = false

fvg_bull_mitigated := false
fvg_bear_mitigated := false

// Mitigate bullish FVGs (iterate reverse to avoid index shift)
if array.size(fvg_bull_tops) > 0
    j = array.size(fvg_bull_tops) - 1
    while j >= 0
        fvg_top = array.get(fvg_bull_tops, j)
        fvg_btm = array.get(fvg_bull_btms, j)
        // Partial: price wicks into gap; Full: close fills entire gap
        breached = fvg_mitigate == 'Partial' ? low <= fvg_top : close <= fvg_btm
        if breached
            bx  = array.get(fvg_bull_boxes, j)
            lbl = array.get(fvg_bull_lbls,  j)
            box.delete(bx)
            label.delete(lbl)
            array.remove(fvg_bull_tops,  j)
            array.remove(fvg_bull_btms,  j)
            array.remove(fvg_bull_lefts, j)
            array.remove(fvg_bull_boxes, j)
            array.remove(fvg_bull_lbls,  j)
            fvg_bull_mitigated := true
        j -= 1

// Mitigate bearish FVGs
if array.size(fvg_bear_tops) > 0
    j = array.size(fvg_bear_tops) - 1
    while j >= 0
        fvg_top = array.get(fvg_bear_tops, j)
        fvg_btm = array.get(fvg_bear_btms, j)
        breached = fvg_mitigate == 'Partial' ? high >= fvg_btm : close >= fvg_top
        if breached
            bx  = array.get(fvg_bear_boxes, j)
            lbl = array.get(fvg_bear_lbls,  j)
            box.delete(bx)
            label.delete(lbl)
            array.remove(fvg_bear_tops,  j)
            array.remove(fvg_bear_btms,  j)
            array.remove(fvg_bear_lefts, j)
            array.remove(fvg_bear_boxes, j)
            array.remove(fvg_bear_lbls,  j)
            fvg_bear_mitigated := true
        j -= 1

// Reposition FVG labels to current bar on each tick — keeps them at the right edge of the extended box
if barstate.islast and show_fvg_labels
    if array.size(fvg_bull_lbls) > 0
        for k = 0 to array.size(fvg_bull_lbls) - 1
            lbl   = array.get(fvg_bull_lbls, k)
            top_v = array.get(fvg_bull_tops,  k)
            btm_v = array.get(fvg_bull_btms,  k)
            label.set_xy(lbl, time, math.avg(top_v, btm_v))
            label.set_style(lbl, label.style_label_left)

    if array.size(fvg_bear_lbls) > 0
        for k = 0 to array.size(fvg_bear_lbls) - 1
            lbl   = array.get(fvg_bear_lbls, k)
            top_v = array.get(fvg_bear_tops,  k)
            btm_v = array.get(fvg_bear_btms,  k)
            label.set_xy(lbl, time, math.avg(top_v, btm_v))
            label.set_style(lbl, label.style_label_left)

// ============================================================================
// PREMIUM & DISCOUNT ZONES
// ============================================================================

// Detect swing high/low using confirmed pivots
pd_ph = ta.pivothigh(high, pd_swing_length, pd_swing_length)
pd_pl = ta.pivotlow(low,   pd_swing_length, pd_swing_length)

// Track the most recent confirmed swing high and swing low
var float pd_swing_high = na
var float pd_swing_low  = na

if not na(pd_ph)
    pd_swing_high := high[pd_swing_length]
if not na(pd_pl)
    pd_swing_low := low[pd_swing_length]

// Compute equilibrium only when both levels are known
pd_range_valid = not na(pd_swing_high) and not na(pd_swing_low) and pd_swing_high > pd_swing_low
pd_equil       = pd_range_valid ? math.avg(pd_swing_high, pd_swing_low) : na

// Current price location relative to equilibrium
in_premium  = pd_range_valid and close > pd_equil
in_discount = pd_range_valid and close < pd_equil

// Draw equilibrium line and shaded zones on last bar only
var line  pd_eq_line  = na
var box   pd_prem_box = na
var box   pd_disc_box = na
var label pd_prem_lbl = na
var label pd_disc_lbl = na

if show_pd and barstate.islast and pd_range_valid
    // Remove old drawings
    line.delete(pd_eq_line)
    box.delete(pd_prem_box)
    box.delete(pd_disc_box)
    label.delete(pd_prem_lbl)
    label.delete(pd_disc_lbl)

    // Equilibrium midline — extends left to the swing high/low reference area
    ref_bar = bar_index - pd_swing_length * 3
    pd_eq_line := line.new(ref_bar, pd_equil, bar_index, pd_equil,
         color  = pd_eq_css,
         style  = line.style_dashed,
         width  = 1,
         extend = extend.right)

    // Shaded zone boxes
    if show_pd_zones
        pd_prem_box := box.new(ref_bar, pd_swing_high, bar_index, pd_equil,
             xloc         = xloc.bar_index,
             extend       = extend.right,
             bgcolor      = pd_premium_css,
             border_color = na)
        pd_disc_box := box.new(ref_bar, pd_equil, bar_index, pd_swing_low,
             xloc         = xloc.bar_index,
             extend       = extend.right,
             bgcolor      = pd_discount_css,
             border_color = na)

    // Labels at the right edge
    pd_prem_lbl := label.new(bar_index, math.avg(pd_swing_high, pd_equil), 'Premium',
         style     = label.style_label_left,
         color     = color.new(color.black, 100),
         textcolor = color.new(#ef5350, 30),
         size      = size.tiny)
    pd_disc_lbl := label.new(bar_index, math.avg(pd_equil, pd_swing_low), 'Discount',
         style     = label.style_label_left,
         color     = color.new(color.black, 100),
         textcolor = color.new(#26a69a, 30),
         size      = size.tiny)

// ============================================================================
// LIQUIDITY DETECTION & SWEEPS
// ============================================================================

liq_ph = ta.pivothigh(high, liq_length, liq_length)
liq_pl = ta.pivotlow(low, liq_length, liq_length)

var liq_bsl_prices = array.new_float(0)
var liq_bsl_lefts  = array.new_int(0)
var liq_bsl_lines  = array.new_line(0)
var liq_bsl_lbls   = array.new_label(0)
var liq_bsl_swept  = array.new_bool(0)

var liq_ssl_prices = array.new_float(0)
var liq_ssl_lefts  = array.new_int(0)
var liq_ssl_lines  = array.new_line(0)
var liq_ssl_lbls   = array.new_label(0)
var liq_ssl_swept  = array.new_bool(0)

var bool bsl_sweep_alert = false
var bool ssl_sweep_alert = false
bsl_sweep_alert := false
ssl_sweep_alert := false

float liq_tol_val = liq_tolerance * syminfo.mintick

// ─── BSL Registration ───────────────────────────────────────────────────────
if show_liq and not na(liq_ph)
    float new_bsl = high[liq_length]
    int   new_bar = time[liq_length]
    bool  merged  = false

    if array.size(liq_bsl_prices) > 0
        for i = array.size(liq_bsl_prices) - 1 to 0 by 1
            float p     = array.get(liq_bsl_prices, i)
            bool  swept = array.get(liq_bsl_swept, i)
            if not swept and math.abs(new_bsl - p) <= liq_tol_val
                merged := true
                if new_bsl > p
                    array.set(liq_bsl_prices, i, new_bsl)
                    line  ln = array.get(liq_bsl_lines, i)
                    label lb = array.get(liq_bsl_lbls, i)
                    line.set_y1(ln, new_bsl)
                    line.set_y2(ln, new_bsl)
                    label.set_y(lb, new_bsl)
                break

    if not merged
        array.unshift(liq_bsl_prices, new_bsl)
        array.unshift(liq_bsl_lefts,  new_bar)
        array.unshift(liq_bsl_swept,  false)
        l = line.new(new_bar, new_bsl, time, new_bsl, 
             xloc  = xloc.bar_time, 
             color = liq_bsl_css, 
             width = 1, 
             style = line.style_solid)
        array.unshift(liq_bsl_lines, l)
        b = label.new(time + int(nz(time - time[1])) * 5, new_bsl, "BSL", 
             xloc      = xloc.bar_time, 
             color     = color.new(color.black, 100), 
             textcolor = liq_bsl_css, 
             style     = label.style_label_left, 
             size      = size.tiny)
        array.unshift(liq_bsl_lbls, b)

        if array.size(liq_bsl_prices) > liq_max
            line.delete(array.pop(liq_bsl_lines))
            label.delete(array.pop(liq_bsl_lbls))
            array.pop(liq_bsl_prices)
            array.pop(liq_bsl_lefts)
            array.pop(liq_bsl_swept)

// ─── SSL Registration ───────────────────────────────────────────────────────
if show_liq and not na(liq_pl)
    float new_ssl = low[liq_length]
    int   new_bar = time[liq_length]
    bool  merged  = false

    if array.size(liq_ssl_prices) > 0
        for i = array.size(liq_ssl_prices) - 1 to 0 by 1
            float p     = array.get(liq_ssl_prices, i)
            bool  swept = array.get(liq_ssl_swept, i)
            if not swept and math.abs(new_ssl - p) <= liq_tol_val
                merged := true
                if new_ssl < p
                    array.set(liq_ssl_prices, i, new_ssl)
                    line  ln = array.get(liq_ssl_lines, i)
                    label lb = array.get(liq_ssl_lbls, i)
                    line.set_y1(ln, new_ssl)
                    line.set_y2(ln, new_ssl)
                    label.set_y(lb, new_ssl)
                break

    if not merged
        array.unshift(liq_ssl_prices, new_ssl)
        array.unshift(liq_ssl_lefts,  new_bar)
        array.unshift(liq_ssl_swept,  false)
        l = line.new(new_bar, new_ssl, time, new_ssl, 
             xloc  = xloc.bar_time, 
             color = liq_ssl_css, 
             width = 1, 
             style = line.style_solid)
        array.unshift(liq_ssl_lines, l)
        b = label.new(time + int(nz(time - time[1])) * 5, new_ssl, "SSL", 
             xloc      = xloc.bar_time, 
             color     = color.new(color.black, 100), 
             textcolor = liq_ssl_css, 
             style     = label.style_label_left, 
             size      = size.tiny)
        array.unshift(liq_ssl_lbls, b)

        if array.size(liq_ssl_prices) > liq_max
            line.delete(array.pop(liq_ssl_lines))
            label.delete(array.pop(liq_ssl_lbls))
            array.pop(liq_ssl_prices)
            array.pop(liq_ssl_lefts)
            array.pop(liq_ssl_swept)

// ─── Sweep Engine & Extension ───────────────────────────────────────────────
if show_liq
    int liq_offset_t = int(nz(time - time[1])) * 5
    // BSL
    if array.size(liq_bsl_prices) > 0
        for i = array.size(liq_bsl_prices) - 1 to 0 by 1
            float p     = array.get(liq_bsl_prices, i)
            bool  swept = array.get(liq_bsl_swept, i)
            line  ln    = array.get(liq_bsl_lines, i)
            label lb    = array.get(liq_bsl_lbls, i)
            if not swept
                line.set_x2(ln, time)
                label.set_x(lb, time + liq_offset_t)
                
                if high >= p
                    if barstate.isconfirmed
                        array.set(liq_bsl_swept, i, true)
                        line.set_color(ln, color.new(liq_bsl_css, 70))
                        line.set_style(ln, line.style_dashed)
                        label.set_textcolor(lb, color.new(liq_bsl_css, 50))
                        label.set_text(lb, "BSL (Taken)")
                        bsl_sweep_alert := true

    // SSL
    if array.size(liq_ssl_prices) > 0
        for i = array.size(liq_ssl_prices) - 1 to 0 by 1
            float p     = array.get(liq_ssl_prices, i)
            bool  swept = array.get(liq_ssl_swept, i)
            line  ln    = array.get(liq_ssl_lines, i)
            label lb    = array.get(liq_ssl_lbls, i)
            if not swept
                line.set_x2(ln, time)
                label.set_x(lb, time + liq_offset_t)
                
                if low <= p
                    if barstate.isconfirmed
                        array.set(liq_ssl_swept, i, true)
                        line.set_color(ln, color.new(liq_ssl_css, 70))
                        line.set_style(ln, line.style_dashed)
                        label.set_textcolor(lb, color.new(liq_ssl_css, 50))
                        label.set_text(lb, "SSL (Taken)")
                        ssl_sweep_alert := true

// ============================================================================
// ICT ENTRY MODEL — STATE MACHINE
// ============================================================================
// Tracks the 4-step ICT sequence per direction.
// Runs AFTER the sweep engine so ssl/bsl_sweep_alert flags are current.
//
// State per direction:
//   0 = idle
//   1 = sweep confirmed, waiting for displacement
//   2 = displacement confirmed, waiting for MSS
//   3 = MSS confirmed — valid retrace window open
//
// When state == 3, any OB/FVG box that price is currently inside gets its
// bgcolor changed to the "valid" color. No arrows or signals are drawn.

var int   ict_bull_state   = 0   // bullish setup stage
var int   ict_bear_state   = 0   // bearish setup stage
var int   ict_bull_bar     = 0   // bar_index when current bull stage was entered
var int   ict_bear_bar     = 0   // bar_index when current bear stage was entered
var float ict_bull_mss_lvl = na  // swing high price must close above for bull MSS
var float ict_bear_mss_lvl = na  // swing low  price must close below for bear MSS

// Retrace flags used for alerts (reset each bar)
var bool ict_bull_retrace = false
var bool ict_bear_retrace = false
ict_bull_retrace := false
ict_bear_retrace := false

if ict_enable and barstate.isconfirmed
    // ── BULLISH: SSL swept → bullish displacement → MSS → retrace into bull OB/FVG ──

    // Step 1: SSL sweep starts the sequence (P&D filter: only in Discount)
    pd_bull_ok = not pd_use_filter or not show_pd or in_discount
    if ssl_sweep_alert and ict_bull_state == 0 and pd_bull_ok
        ict_bull_state   := 1
        ict_bull_bar     := n
        ict_bull_mss_lvl := ta.highest(high, ict_mss_lookback)

    // Step 2: Bullish displacement after sweep
    if ict_bull_state == 1 and disp_bull
        ict_bull_state := 2
        ict_bull_bar   := n

    // Step 3: MSS — close above captured swing high
    if ict_bull_state == 2 and not na(ict_bull_mss_lvl) and close > ict_bull_mss_lvl
        ict_bull_state := 3
        ict_bull_bar   := n

    // Reset bull state on window expiry
    if ict_bull_state > 0 and n - ict_bull_bar > ict_model_window
        ict_bull_state   := 0
        ict_bull_mss_lvl := na

    // ── BEARISH: BSL swept → bearish displacement → MSS → retrace into bear OB/FVG ──

    // Step 1: BSL sweep starts the sequence (P&D filter: only in Premium)
    pd_bear_ok = not pd_use_filter or not show_pd or in_premium
    if bsl_sweep_alert and ict_bear_state == 0 and pd_bear_ok
        ict_bear_state   := 1
        ict_bear_bar     := n
        ict_bear_mss_lvl := ta.lowest(low, ict_mss_lookback)

    // Step 2: Bearish displacement after sweep
    if ict_bear_state == 1 and disp_bear
        ict_bear_state := 2
        ict_bear_bar   := n

    // Step 3: MSS — close below captured swing low
    if ict_bear_state == 2 and not na(ict_bear_mss_lvl) and close < ict_bear_mss_lvl
        ict_bear_state := 3
        ict_bear_bar   := n

    // Reset bear state on window expiry
    if ict_bear_state > 0 and n - ict_bear_bar > ict_model_window
        ict_bear_state   := 0
        ict_bear_mss_lvl := na

// ── Step 4: Zone highlighting — paint valid OBs and FVGs ────────────────────
// ob_box_bull / ob_box_bear are pre-allocated to ext_last slots (index matches data arrays)

if ict_enable and ict_bull_state == 3
    // Bullish OBs
    ob_last = math.min(bull_ext_last - 1, array.size(bull_top) - 1)
    if ob_last >= 0
        for i = 0 to ob_last
            t_v = array.get(bull_top, i)
            b_v = array.get(bull_btm, i)
            if low <= t_v and high >= b_v
                bx = array.get(ob_box_bull, i)
                if not na(bx)
                    box.set_bgcolor(bx, ict_bull_valid_css)
                ict_bull_retrace := true
    // Bullish FVGs
    fvg_sz = array.size(fvg_bull_tops)
    if fvg_sz > 0
        for i = 0 to fvg_sz - 1
            t_v = array.get(fvg_bull_tops, i)
            b_v = array.get(fvg_bull_btms, i)
            if low <= t_v and high >= b_v
                bx = array.get(fvg_bull_boxes, i)
                if not na(bx)
                    box.set_bgcolor(bx, ict_bull_valid_css)
                ict_bull_retrace := true

if ict_enable and ict_bear_state == 3
    // Bearish OBs
    ob_last = math.min(bear_ext_last - 1, array.size(bear_top) - 1)
    if ob_last >= 0
        for i = 0 to ob_last
            t_v = array.get(bear_top, i)
            b_v = array.get(bear_btm, i)
            if low <= t_v and high >= b_v
                bx = array.get(ob_box_bear, i)
                if not na(bx)
                    box.set_bgcolor(bx, ict_bear_valid_css)
                ict_bear_retrace := true
    // Bearish FVGs
    fvg_sz = array.size(fvg_bear_tops)
    if fvg_sz > 0
        for i = 0 to fvg_sz - 1
            t_v = array.get(fvg_bear_tops, i)
            b_v = array.get(fvg_bear_btms, i)
            if low <= t_v and high >= b_v
                bx = array.get(fvg_bear_boxes, i)
                if not na(bx)
                    box.set_bgcolor(bx, ict_bear_valid_css)
                ict_bear_retrace := true

// ============================================================================
// PLOTS — PREMIUM & DISCOUNT
// ============================================================================

// Invisible reference plots for data window awareness (no visual clutter)
plot(show_pd ? pd_equil : na, 'Equilibrium (50%)', color.new(pd_eq_css, 0), 1,
     plot.style_linebr, force_overlay = true, display = display.data_window)
plot(show_pd ? pd_swing_high : na, 'Swing High (P&D)', color.new(#ef5350, 60), 1,
     plot.style_linebr, force_overlay = true, display = display.data_window)
plot(show_pd ? pd_swing_low : na, 'Swing Low (P&D)',  color.new(#26a69a, 60), 1,
     plot.style_linebr, force_overlay = true, display = display.data_window)

// ============================================================================
// PLOTS — SESSIONS
// ============================================================================



// Session dividers
plotshape(sesa_on and show_ses_div and show_sesa,               '·',   shape.square,  location.bottom, na, text = '.',  textcolor = sesa_css, size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)
plotshape(is_sesa != is_sesa[1] and show_ses_div and show_sesa, 'NYE', shape.labelup, location.bottom, na, text = '❚', textcolor = sesa_css, size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)

plotshape(sesb_on and show_ses_div and show_sesb,               '·',   shape.labelup, location.bottom, na, text = '.',  textcolor = sesb_css, size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)
plotshape(is_sesb != is_sesb[1] and show_ses_div and show_sesb, 'LDN', shape.labelup, location.bottom, na, text = '❚', textcolor = sesb_css, size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)

plotshape(sesc_on and show_ses_div and show_sesc,               '·',   shape.square,  location.bottom, na, text = '.',  textcolor = sesc_css, size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)
plotshape(is_sesc != is_sesc[1] and show_ses_div and show_sesc, 'TYO', shape.labelup, location.bottom, na, text = '❚', textcolor = sesc_css, size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)

plotshape(sesd_on and show_ses_div and show_sesd,               '·',   shape.labelup, location.bottom, na, text = '.',  textcolor = sesd_css, size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)
plotshape(is_sesd != is_sesd[1] and show_ses_div and show_sesd, 'SYD', shape.labelup, location.bottom, na, text = '❚', textcolor = sesd_css, size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)

// ============================================================================
// DAILY DIVIDERS
// ============================================================================

day        = dayofweek
day_change = show_day_div and day != day[1]

if day_change
    line.new(n, close + syminfo.mintick, n, close - syminfo.mintick,
         color  = color.new(color.gray, 40),
         extend = extend.both,
         style  = line.style_dashed)

plotshape(day_change and day == 1, 'Sunday',    shape.labeldown, location.top, na, text = 'Sun', textcolor = color.new(color.gray, 30), size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)
plotshape(day_change and day == 2, 'Monday',    shape.labeldown, location.top, na, text = 'Mon', textcolor = color.new(color.gray, 30), size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)
plotshape(day_change and day == 3, 'Tuesday',   shape.labeldown, location.top, na, text = 'Tue', textcolor = color.new(color.gray, 30), size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)
plotshape(day_change and day == 4, 'Wednesday', shape.labeldown, location.top, na, text = 'Wed', textcolor = color.new(color.gray, 30), size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)
plotshape(day_change and day == 5, 'Thursday',  shape.labeldown, location.top, na, text = 'Thu', textcolor = color.new(color.gray, 30), size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)
plotshape(day_change and day == 6, 'Friday',    shape.labeldown, location.top, na, text = 'Fri', textcolor = color.new(color.gray, 30), size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)
plotshape(day_change and day == 7, 'Saturday',  shape.labeldown, location.top, na, text = 'Sat', textcolor = color.new(color.gray, 30), size = size.tiny, display = display.all - display.status_line, editable = false, force_overlay = true)

// ============================================================================
// PLOTS — ORDER BLOCKS
// ============================================================================

plot(bull_ob, 'Bull OB', bull_css, 2, plot.style_linebr, offset = -length, display = display.none, force_overlay = true)
plot(bear_ob, 'Bear OB', bear_css, 2, plot.style_linebr, offset = -length, display = display.none, force_overlay = true)

// ============================================================================
// PLOTS — DISPLACEMENT
// ============================================================================

// Candle color override — draws a tinted candle on top of displacement bars
plotcandle(show_disp and (disp_bull or disp_bear) ? open : na, high, low, close, 'Displacement Candle', disp_bull ? color.new(disp_bull_css, 20) : color.new(disp_bear_css, 20), disp_bull ? color.new(disp_bull_css, 20) : color.new(disp_bear_css, 20), force_overlay = true)

// ============================================================================
// SMART ALERTS — ORDER BLOCKS
// ============================================================================

bool ob_bull_alert = bool(bull_ob)
bool ob_bear_alert = bool(bear_ob)

if ob_bull_alert
    alert(syminfo.ticker + ' — Bullish Order Block Formed @ ' + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
if ob_bear_alert
    alert(syminfo.ticker + ' — Bearish Order Block Formed @ ' + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)

if mitigated_bull
    alert(syminfo.ticker + ' — Bullish Order Block Mitigated @ ' + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
if mitigated_bear
    alert(syminfo.ticker + ' — Bearish Order Block Mitigated @ ' + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)

alertcondition(ob_bull_alert,        'OB Formed (Bullish)',    'Bullish order block detected')
alertcondition(ob_bear_alert,        'OB Formed (Bearish)',    'Bearish order block detected')
alertcondition(bool(mitigated_bull), 'OB Mitigated (Bullish)', 'Bullish order block mitigated')
alertcondition(bool(mitigated_bear), 'OB Mitigated (Bearish)', 'Bearish order block mitigated')

// ============================================================================
// SMART ALERTS — FAIR VALUE GAPS
// ============================================================================

if fvg_bull_cond
    alert(syminfo.ticker + ' — Bullish FVG Formed @ ' + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
if fvg_bear_cond
    alert(syminfo.ticker + ' — Bearish FVG Formed @ ' + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)

if fvg_bull_mitigated
    alert(syminfo.ticker + ' — Bullish FVG Mitigated @ ' + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
if fvg_bear_mitigated
    alert(syminfo.ticker + ' — Bearish FVG Mitigated @ ' + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)

alertcondition(fvg_bull_cond,       'FVG Formed (Bullish)',    'Bullish fair value gap detected')
alertcondition(fvg_bear_cond,       'FVG Formed (Bearish)',    'Bearish fair value gap detected')
alertcondition(fvg_bull_mitigated,  'FVG Mitigated (Bullish)', 'Bullish fair value gap mitigated')
alertcondition(fvg_bear_mitigated,  'FVG Mitigated (Bearish)', 'Bearish fair value gap mitigated')

// ============================================================================
// SMART ALERTS — LIQUIDITY
// ============================================================================

if bsl_sweep_alert
    alert(syminfo.ticker + ' — Buy-Side Liquidity Swept @ ' + str.tostring(high, format.mintick), alert.freq_once_per_bar_close)
if ssl_sweep_alert
    alert(syminfo.ticker + ' — Sell-Side Liquidity Swept @ ' + str.tostring(low, format.mintick), alert.freq_once_per_bar_close)

alertcondition(bsl_sweep_alert, 'Liquidity Swept (BSL)', 'BSL level was swept')
alertcondition(ssl_sweep_alert, 'Liquidity Swept (SSL)', 'SSL level was swept')

// ============================================================================
// SMART ALERTS — DISPLACEMENT
// ============================================================================

if disp_bull
    alert(syminfo.ticker + ' — Bullish Displacement @ ' + str.tostring(close, format.mintick) + '  (body ' + str.tostring(disp_body, format.mintick) + ' / ATR ' + str.tostring(sys_atr, format.mintick) + ')', alert.freq_once_per_bar_close)
if disp_bear
    alert(syminfo.ticker + ' — Bearish Displacement @ ' + str.tostring(close, format.mintick) + '  (body ' + str.tostring(disp_body, format.mintick) + ' / ATR ' + str.tostring(sys_atr, format.mintick) + ')', alert.freq_once_per_bar_close)

alertcondition(disp_bull, 'Displacement (Bullish)', 'Strong bullish impulse candle detected')
alertcondition(disp_bear, 'Displacement (Bearish)', 'Strong bearish impulse candle detected')

// ============================================================================
// SMART ALERTS — ICT ENTRY MODEL
// ============================================================================

if ict_enable and ict_alert_valid and barstate.isconfirmed
    if ict_bull_retrace
        alert(syminfo.ticker + ' — ICT Bullish Setup: price in valid OB/FVG @ ' + str.tostring(close, format.mintick) + '  (SSL swept → Disp → MSS → retrace)', alert.freq_once_per_bar_close)
    if ict_bear_retrace
        alert(syminfo.ticker + ' — ICT Bearish Setup: price in valid OB/FVG @ ' + str.tostring(close, format.mintick) + '  (BSL swept → Disp → MSS → retrace)', alert.freq_once_per_bar_close)

alertcondition(ict_enable and ict_bull_retrace, 'ICT Valid Bullish Setup', 'Full ICT bullish sequence confirmed — price in OB/FVG')
alertcondition(ict_enable and ict_bear_retrace, 'ICT Valid Bearish Setup', 'Full ICT bearish sequence confirmed — price in OB/FVG')

// ============================================================================
// SMART ALERTS — PREMIUM & DISCOUNT
// ============================================================================

// Detect first cross into each zone (confirmed bar)
pd_cross_premium  = show_pd and pd_range_valid and barstate.isconfirmed and in_premium  and not in_premium[1]
pd_cross_discount = show_pd and pd_range_valid and barstate.isconfirmed and in_discount and not in_discount[1]

if pd_cross_premium
    alert(syminfo.ticker + ' — Price entered Premium zone (above EQ ' + str.tostring(pd_equil, format.mintick) + ')', alert.freq_once_per_bar_close)
if pd_cross_discount
    alert(syminfo.ticker + ' — Price entered Discount zone (below EQ ' + str.tostring(pd_equil, format.mintick) + ')', alert.freq_once_per_bar_close)

alertcondition(pd_cross_premium,  'Entered Premium Zone',  'Price crossed above equilibrium into Premium')
alertcondition(pd_cross_discount, 'Entered Discount Zone', 'Price crossed below equilibrium into Discount')
